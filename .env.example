# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. Never commit real secrets.

# ---- Clerk ----
# Get these from https://dashboard.clerk.com after creating an application.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs. Defaults below match the routes scaffolded in this app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---- Supabase ----
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic ----
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- USITC HTS API ----
# Public API — no key required. Override only if you need a proxy or mock.
USITC_API_BASE=https://hts.usitc.gov
